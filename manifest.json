{
  "manifest_version": 3,
  "name": "cyshot",
  "version": "1.1",
  "description": "Web page data extractor, screenshot capture, screen recorder, net tracer, and cookie manager.",
  "permissions": [
    "activeTab", 
    "scripting", 
    "storage", 
    "downloads", 
    "unlimitedStorage", 
    "cookies"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "img/cycyshot.png",
    "48": "img/cycyshot.png",
    "128": "img/cycyshot.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "img/cycyshot.png",
      "48": "img/cycyshot.png",
      "128": "img/cycyshot.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/observer.js"],
      "matches": ["<all_urls>"]
    }
  ]
}